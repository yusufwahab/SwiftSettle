# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database (Supabase) — required
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT — required (any random long string works for JWT_SECRET/REFRESH_TOKEN_SECRET)
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_secret
REFRESH_TOKEN_EXPIRE=30d

# Nomba APIs — required for virtual accounts, transfers, webhooks.
# NOMBA_API_KEY / NOMBA_API_SECRET are the Client ID / Private Key Nomba
# gave you (use the TEST pair while developing, LIVE only once you're ready
# for real money movement — never mix the two).
NOMBA_API_KEY=your_nomba_client_id
NOMBA_API_SECRET=your_nomba_private_key
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_WEBHOOK_SECRET=choose_a_long_random_string_and_enter_the_same_one_in_the_nomba_dashboard
# The "Main (parent) Account ID" Nomba gave you — goes in the accountId
# header on every call, always, even sub-account-scoped ones.
NOMBA_PARENT_ACCOUNT_ID=your_parent_account_id
# The "sub-account ID" Nomba gave you — SwiftSettle's own account under
# that parent. One fixed value for the whole business, not per worker.
# This is also the value you submit in Nomba's "tell us your webhook URL"
# form alongside your webhook URL.
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id

# Platform Webhooks (DoorDash, Jumia, Uber, ...)
PLATFORM_WEBHOOK_SECRET=your_platform_secret

# Admin/internal endpoints (GET /api/admin/behavioral-analytics) — not in
# the original prompt's env list, added because that endpoint has no
# worker to authenticate as and needs some form of gate.
ADMIN_API_KEY=choose_a_long_random_string

# Brevo — required for real email delivery (signup verification codes and
# every other notification). Without it set, emails log to the server
# console instead of sending, so local development still works end-to-end
# without a Brevo account. BREVO_SENDER_EMAIL must be a sender you've
# verified in Brevo's dashboard, or sends will be rejected.
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=notifications@swiftsettle.app
BREVO_SENDER_NAME=SwiftSettle

# Logging
LOG_LEVEL=info
SENTRY_DSN=optional_sentry_url

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://swiftsettle.app
