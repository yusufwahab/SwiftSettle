# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database (Supabase) — required
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT — required (any random long string works for JWT_SECRET/REFRESH_TOKEN_SECRET)
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_secret
REFRESH_TOKEN_EXPIRE=30d

# Nomba APIs — required for virtual accounts, transfers, webhooks.
# Variable names below match exactly what Nomba's own onboarding email
# calls each value — copy them straight across, no translation needed.
# Both TEST and LIVE pairs are kept here at the same time; NOMBA_MODE picks
# which one is actually used. Use "test" while developing — switch to
# "live" only once you're ready to move real money.
NOMBA_MODE=test
NOMBA_TEST_CLIENT_ID=your_nomba_test_client_id
NOMBA_TEST_PRIVATE_KEY=your_nomba_test_private_key
NOMBA_LIVE_CLIENT_ID=your_nomba_live_client_id
NOMBA_LIVE_PRIVATE_KEY=your_nomba_live_private_key
# TEST tokens only work against the sandbox host — LIVE tokens only work
# against the production host. Leave this unset and it'll default correctly
# based on NOMBA_MODE; only set it explicitly if you need to override that.
# test:  https://sandbox.nomba.com
# live:  https://api.nomba.com
NOMBA_BASE_URL=
# If you're on the NombaHackathon2026 program, Nomba assigns this to you as
# a FIXED value shown on their webhook-registration form — use exactly what
# they show you (do not invent your own). For a standalone Nomba merchant
# integration outside that program, you do choose this value yourself, and
# enter that same value as the "signature key" in Nomba's dashboard.
NOMBA_WEBHOOK_SECRET=check_your_nomba_webhook_form_or_choose_a_long_random_string
# The "Main (parent) Account ID" Nomba gave you — goes in the accountId
# header on every call, always, even sub-account-scoped ones.
NOMBA_MAIN_ACCOUNT_ID=your_main_parent_account_id
# The "sub-account ID" Nomba gave you — SwiftSettle's own account under
# that parent. One fixed value for the whole business, not per worker.
# This is also the value you submit in Nomba's "tell us your webhook URL"
# form alongside your webhook URL.
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id

# Platform Webhooks (DoorDash, Jumia, Uber, ...)
PLATFORM_WEBHOOK_SECRET=your_platform_secret

# Admin/internal endpoints (GET /api/admin/behavioral-analytics) — not in
# the original prompt's env list, added because that endpoint has no
# worker to authenticate as and needs some form of gate.
ADMIN_API_KEY=choose_a_long_random_string

# Brevo — required for real email delivery (signup verification codes and
# every other notification). Without it set, emails log to the server
# console instead of sending, so local development still works end-to-end
# without a Brevo account. BREVO_SENDER_EMAIL must be a sender you've
# verified in Brevo's dashboard, or sends will be rejected.
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=notifications@swiftsettle.app
BREVO_SENDER_NAME=SwiftSettle

# Logging
LOG_LEVEL=info
SENTRY_DSN=optional_sentry_url

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://swiftsettle.app
