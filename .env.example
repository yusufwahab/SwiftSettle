# Frontend (Vite) environment variables.
# Copy to .env.local for local development.

# "mock" (default) uses the in-browser fake service layer — no backend
# needed. Set to "live" to call the real SwiftSettle backend in server/.
VITE_API_MODE=mock

# Only used when VITE_API_MODE=live. Must include the /api prefix.
VITE_API_URL=http://localhost:5000/api
